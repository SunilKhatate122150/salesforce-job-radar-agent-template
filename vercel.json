{
  "version": 2,
  "functions": {
    "api/server.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.js" },
    { "source": "/(.*)", "destination": "/public/$1" },
    { "source": "/", "destination": "/public/index.html" }
  ]
}
